{
  "name": "@daks.dev/.dev.nic",
  "version": "0.1.0",
  "description": "NIC",
  "private": false,
  "scripts": {
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "start": "node build/index.js",
    "cluster": "node run/cluster.js",
    "dev": "vite dev --port=3000",
    "lint": "prettier --plugin-search-dir . --check . && eslint .",
    "format": "prettier --plugin-search-dir . --write .",
    "build": "vite build",
    "preview": "vite preview --port=3000",
    "test:integration": "playwright test -c tests/",
    "test:unit": "vitest --ui",
    "test": "pnpm run test:integration && pnpm run test:unit",
    "run:update": "pnpm up"
  },
  "devDependencies": {
    "@daks.dev/svelte.sdk": "^0.1.0",
    "@iconify/svelte": "^3.1.4",
    "@nanostores/persistent": "^0.9.1",
    "@playwright/test": "^1.39.0",
    "@rollup/pluginutils": "^5.0.5",
    "@sveltejs/adapter-node": "^1.3.1",
    "@sveltejs/adapter-static": "^2.0.3",
    "@sveltejs/kit": "^1.26.0",
    "@types/html-minifier-terser": "^7.0.1",
    "@types/node": "^20.8.7",
    "@vitest/ui": "^0.34.6",
    "autoprefixer": "^10.4.16",
    "classnames": "^2.3.2",
    "cssnano": "^6.0.1",
    "cssnano-preset-advanced": "^6.0.1",
    "dotenv": "^16.3.1",
    "esm-env": "^1.0.0",
    "flowbite": "^1.8.1",
    "flowbite-svelte": "^0.44.18",
    "iconify-icon": "^1.0.8",
    "js-yaml": "4.1.0",
    "jsdom": "22.1.0",
    "html-minifier-terser": "^7.2.0",
    "nanostores": "^0.9.4",
    "postcss": "^8.4.31",
    "svelte": "^4.2.2",
    "svelte-check": "^3.5.2",
    "tailwind-merge": "^1.14.0",
    "tailwindcss": "^3.3.3",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vanilla-lazyload": "^17.8.5",
    "vite": "^4.5.0",
    "vite-imagetools": "^5.1.2",
    "vitest": "^0.34.6"
  },
  "type": "module",
  "engines": {
    "node": ">=16.20.2",
    "pnpm": "^8.7.0"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daks-dev/.dev.nic"
  },
  "bugs": "https://github.com/daks-dev/.dev.nic/issues",
  "author": {
    "name": "DVA",
    "email": "mail@daks.dev",
    "url": "https://daks.dev"
  },
  "homepage": "https://stroyexp.info"
}
