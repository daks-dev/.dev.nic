{
  "name": "@daks.dev/.dev.nic",
  "version": "0.1.5",
  "description": "NIC",
  "private": false,
  "scripts": {
    "start": "node build/index.js",
    "cluster": "node run/cluster.js",
    "dev": "vite dev --port=3000",
    "build": "vite build",
    "preview": "vite preview --port=3000",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:integration": "playwright test -c tests/",
    "test:unit": "vitest --ui",
    "test": "pnpm run test:integration && pnpm run test:unit",
    "run:prettier": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss",
    "lint": "pnpm run:prettier --check . && eslint .",
    "format": "pnpm run:prettier --write .",
    "run:update": "pnpm up"
  },
  "devDependencies": {
    "@daks.dev/svelte.sdk": "^0.1.8",
    "@iconify/svelte": "^4.2.0",
    "@nanostores/persistent": "^0.10.2",
    "@playwright/test": "^1.50.1",
    "@sveltejs/adapter-node": "^1.3.1",
    "@sveltejs/adapter-static": "^2.0.3",
    "@sveltejs/kit": "^1.27.6",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.5",
    "@types/postcss-import": "^14.0.3",
    "@vitest/ui": "^0.34.6",
    "autoprefixer": "^10.4.20",
    "classnames": "^2.5.1",
    "cookie": "^1.0.2",
    "cssnano": "^7.0.6",
    "cssnano-preset-advanced": "^7.0.6",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "esm-env": "^1.2.2",
    "flowbite": "^3.1.2",
    "flowbite-svelte": "^0.44.19",
    "html-minifier-terser": "^7.2.0",
    "iconify-icon": "^2.3.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.0.0",
    "nanostores": "^0.11.4",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "svelte": "^4.2.19",
    "svelte-check": "3.6.7",
    "tailwind-merge": "1.14.0",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vanilla-lazyload": "^19.1.3",
    "vite": "^4.5.9",
    "vite-imagetools": "^7.0.5",
    "vitest": "^0.34.6"
  },
  "type": "module",
  "engines": {
    "node": ">=16.20.2",
    "pnpm": ">=8.7.0"
  },
  "browserslist": [
    "last 2 version",
    "not dead"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daks-dev/.dev.nic.git"
  },
  "bugs": "https://github.com/daks-dev/.dev.nic/issues",
  "author": {
    "name": "DVA",
